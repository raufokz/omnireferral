APP_NAME=OmniReferral
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=omnireferral
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: SESSION_DOMAIN=.omnireferrals.com
# Production: SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=database
MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="admin@omnireferrals.com"
MAIL_FROM_NAME="${APP_NAME}"

# Welcome credentials email sender (used for new account provisioning)
MAIL_CREDENTIALS_FROM_ADDRESS="admin@omnireferrals.com"
MAIL_CREDENTIALS_FROM_NAME="OmniReferral Admin"

# Public contact ("leave phone blank to show email-first support only")
OMNI_SUPPORT_EMAIL="support@omnireferrals.com"
OMNI_INFO_EMAIL="info@omnireferrals.com"
OMNI_SUPPORT_PHONE_E164="+12312813131"
OMNI_SUPPORT_PHONE_DISPLAY="+1 231-281-3131"
OMNI_HQ_LOCATION_LABEL="Salem, MA, USA"
OMNI_MAPS_EMBED_QUERY="Salem, MA, USA"
OMNI_HQ_ADDRESS_STREET=""
OMNI_HQ_ADDRESS_LOCALITY="Salem"
OMNI_HQ_ADDRESS_REGION="MA"
OMNI_HQ_ADDRESS_POSTAL_CODE=""
OMNI_HQ_ADDRESS_COUNTRY="US"
OMNI_OFFICE_HOURS="Mon-Fri, 9am-6pm ET"
OMNI_FACEBOOK_URL="https://www.facebook.com/profile.php?id=61589808382458"
OMNI_INSTAGRAM_URL="https://www.instagram.com/omni.referral/"
OMNI_PINTEREST_URL="https://www.pinterest.com/omnireferral/"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

GOOGLE_MAPS_API_KEY=
GOOGLE_ANALYTICS_MEASUREMENT_ID=G-RKHPD82W4K
GOHIGHLEVEL_API_KEY=
GOHIGHLEVEL_LOCATION_ID=
GOHIGHLEVEL_BASE_URL=https://services.leadconnectorhq.com
GOHIGHLEVEL_WEBHOOK_SECRET=
# GoHighLevel HTTP client tuning (production reliability)
# GOHIGHLEVEL_HTTP_TIMEOUT=10
# GOHIGHLEVEL_HTTP_RETRIES=3
# GOHIGHLEVEL_HTTP_RETRY_SLEEP_MS=500
# Optional: require a per-request nonce header for webhook replay hardening.
# When enabled in production, OmniReferral expects `X-OmniReferral-Webhook-Nonce` on all GoHighLevel webhooks.
# GOHIGHLEVEL_WEBHOOK_REQUIRE_NONCE=false
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

LEAD_AUTO_ASSIGNMENT_ENABLED=false
LEAD_AUTO_ASSIGNMENT_STRATEGY=round_robin

# Security: allow Spatie role-name "Super Admin" to bypass gates (not recommended in production)
# OMNI_ALLOW_SPATIE_SUPER_ADMIN=false

VITE_APP_NAME="${APP_NAME}"
